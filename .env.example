# Токен Telegram-бота (получить у @BotFather)
BOT_TOKEN=

# Telegram ID администраторов через запятую, например: 111111111,222222222
ADMIN_TELEGRAM_IDS=

# Строка подключения к БД.
# PostgreSQL (production): postgresql+asyncpg://vpnbot:vpnbot@db:5432/vpnbot
# SQLite (local/dev):      sqlite+aiosqlite:///./vpnbot.sqlite3
DATABASE_URL=sqlite+aiosqlite:///./vpnbot.sqlite3

# Параметры оплаты/подписки
PAYMENT_AMOUNT_RUB=175
PAYMENT_PERIOD_DAYS=30

# Пробный период (бесплатно, один раз на аккаунт)
TRIAL_PERIOD_DAYS=3

# Текст с реквизитами для ручного перевода (поддерживает несколько строк и HTML,
# напр. <code>...</code> для копирования по тапу). Для многострочного значения
# используйте двойные кавычки и \n.
PAYMENT_DETAILS_TEXT="<code>+79013855871</code> (Альфа-банк по СБП)\n<code>2204 3203 4452 2539</code> (Озон-банк на карту)"

# Контакт поддержки (username или ссылка)
SUPPORT_CONTACT=@support

# Таймаут HTTP-запросов к 3x-ui, секунды
XUI_REQUEST_TIMEOUT=15

# Период фоновой проверки доступности серверов, секунды (0 — отключить)
SERVER_HEALTH_POLL_SECONDS=60

# Период проверки истекающих подписок для уведомлений (за день/час/в момент
# окончания), секунды (0 — отключить уведомления)
EXPIRY_NOTIFY_POLL_SECONDS=300

# Логирование: DEBUG для максимально подробного вывода (отлов ошибок)
LOG_LEVEL=INFO
# Подробный лог запросов к 3x-ui (метод/путь/статус)
XUI_DEBUG=false

# Антишеринг-мониторинг (мягкий режим, без автоблокировки в MVP)
ANTI_SHARING_ENABLED=true
DEVICE_POLICY=soft
DEFAULT_IP_LIMIT=3
WARN_THRESHOLD_24H=5
CRITICAL_THRESHOLD_24H=8
AUTO_BLOCK_ENABLED=false
TRACKING_WINDOW_HOURS=24
# Период фонового сбора IP из 3x-ui, минуты (0 — отключить фоновый сбор)
ANTI_SHARING_POLL_MINUTES=5
